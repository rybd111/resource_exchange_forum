# 环境配置
# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=resource_platform
DB_USER=root
DB_PASSWORD=your_password

# JWT配置
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# 第三方服务配置（需要自行申请）
# 短信服务
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_APP_ID=
SMS_TEMPLATE_ID=

# 实名认证服务
REALNAME_SECRET_ID=
REALNAME_SECRET_KEY=

# 支付服务（微信/支付宝）
WECHAT_MCH_ID=
WECHAT_API_KEY=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
